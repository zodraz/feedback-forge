{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "name": "Python: Feedbackforge DevUI",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbackforge",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/feedbackforge"
            }
        },
        {
            "name": "Python: Feedbackforge DevUI Workflow",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbackforge",
            "args": [
                "workflow"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/feedbackforge"
            }
        },
        {
            "name": "Python: AG-UI",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbackforge",
            "args": [
                "serve"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/feedbackforge"
            }
        },
        {
            "name": "Feedbackforge: Workflow",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbackforge",
            "args": [
                "workflow",
                "--devui"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/feedbackforge"
            }
        },
        {
            "name": "Python: FAQ Generator",
            "type": "debugpy",
            "request": "launch",
            "module": "feedbackforge",
            "args": [
                "faq",
                "--days",
                "30",
                "--max-faqs",
                "10"
            ],
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/faqs"
            }
        },
        {
            "name": "Python: Current File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/feedbackforge"
            }
        },
        {
            "name": "Python: Current File as Module",
            "type": "debugpy",
            "request": "launch",
            "module": "${fileBasenameNoExtension}",
            "console": "integratedTerminal",
            "justMyCode": false,
            "env": {
                "PYTHONPATH": "${workspaceFolder}/src"
            },
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python: Action Planner",
            "type": "debugpy",
            "request": "launch",
            "module": "actionplanner",
            "args": [],
            "console": "integratedTerminal",
            "justMyCode": false,
            "cwd": "${workspaceFolder}/action-planner"
        }
    ]
}