# Azure OpenAI / Azure AI Project
AZURE_AI_PROJECT_ENDPOINT=https://your-project.cognitiveservices.azure.com/
AZURE_OPENAI_RESPONSES_DEPLOYMENT_NAME=gpt-4o

AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_ID=your-client-id
AZURE_CLIENT_SECRET=your-client-secret

# Jira Integration (Required)
JIRA_URL=https://your-company.atlassian.net
JIRA_EMAIL=your-email@company.com
JIRA_API_TOKEN=your-jira-token
JIRA_PROJECT_KEY=FEED  # Default project for feedback issues
JIRA_DEFAULT_ASSIGNEE=unassigned

# A2A Communication
# Base URL for dashboard agent (A2A protocol discovers endpoints via /.well-known/agent.json)
FEEDBACKFORGE_DASHBOARD_URL=http://localhost:8081/
# Set to false to disable calling back to dashboard agent
A2A_ENABLE_CALLBACK=true

# Server Configuration
HOST=0.0.0.0
PORT=8084

# Logging
LOG_LEVEL=INFO
