# Azure AI Configuration
AZURE_AI_PROJECT_ENDPOINT=https://your-project.region.api.azureml.ms
AZURE_AI_MODEL_DEPLOYMENT_NAME=your-deployment-name

# Azure OpenAI (Alternative)
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your-key-here

# API Gateway (if using)
AZURE_API_GATEWAY_ENDPOINT=https://your-apim.azure-api.net/inference
AZURE_API_GATEWAY_KEY=your-api-key-here

# Cosmos DB Configuration (Optional - falls back to in-memory if not set)
# Authentication methods:
#   - auto (default): Uses COSMOS_DB_KEY if set, otherwise DefaultAzureCredential
#   - primary_key: Explicitly use primary key (requires COSMOS_DB_KEY to be set)
#   - default_credential: Explicitly use Azure AD authentication (requires 'az login')
COSMOS_DB_ENDPOINT=https://feedbackforge-db.documents.azure.com:443/
COSMOS_DB_AUTH_METHOD=auto  # Options: auto | primary_key | default_credential
COSMOS_DB_KEY=xvJVbh826H55cnbVeqjucUttn3Srt0Pr2eMKTDA2mhbJZhLMcV2u2UUg8Y99XP8N3GY2zX3gAXdKACDb4WwHCQ==  # Primary key from Azure Portal > Keys (optional)
COSMOS_DB_DATABASE=feedbackforge     # Default: feedbackforge
COSMOS_DB_CONTAINER=feedback         # Default: feedback

# Redis Configuration (Optional - falls back to in-memory if not set)
# Install Redis: docker run -d -p 6379:6379 redis:7-alpine
REDIS_URL=redis://localhost:6379

# Session Configuration
SESSION_TTL=3600  # Session time-to-live in seconds (default: 1 hour)

# OpenTelemetry & Application Insights (Optional - telemetry disabled if not set)
# Get connection string from Azure Portal > Application Insights > Overview > Connection String
APPLICATIONINSIGHTS_CONNECTION_STRING=InstrumentationKey=00000000-0000-0000-0000-000000000000;IngestionEndpoint=https://region.applicationinsights.azure.com/;LiveEndpoint=https://region.livediagnostics.monitor.azure.com/
OTEL_SERVICE_NAME=feedbackforge  # Optional: Override service name
DISABLE_TELEMETRY=false  # Set to "true" to disable telemetry

# Azure AI Search for RAG (Optional - enables semantic search and vector embeddings)
# Create resource: az search service create --name feedbackforge-search --resource-group <rg> --sku basic
AZURE_SEARCH_ENDPOINT=https://feedbackforge-search.search.windows.net
AZURE_SEARCH_API_KEY=your-admin-key-here  # Optional: Uses DefaultAzureCredential if not set
AZURE_SEARCH_INDEX_NAME=feedback-index  # Optional: Default is "feedback-index"

# Azure OpenAI for Embeddings (Required if using RAG)
# Used to generate vector embeddings for semantic search
# NOTE: These are the same as the Azure OpenAI settings above
# AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_KEY are required
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT is the deployment name (not model name) in Azure OpenAI Studio
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-small  # Your deployment name in Azure OpenAI
